# Copy to .env and edit for local development.
ODOO_VERSION=19.0
HTTP_PORT=10019
GEVENT_PORT=20019
POSTGRES_PASSWORD=replace-with-random-db-password
ODOO_MASTER_PASSWORD=replace-with-random-master-password
ODOO_TEST_MODULE=my_module
ODOO_TEST_DB=my_module_test
WPMOO_ENV=dev
WPMOO_SNAPSHOT_RETENTION_COUNT=0

# Required only when intentionally running destructive database actions
# such as resetdb or restore-snapshot with WPMOO_ENV=stage or WPMOO_ENV=prod.
# WPMOO_ALLOW_DESTRUCTIVE=1

# Optional image overrides. Leave commented to use the selected compose file defaults.
# ODOO_IMAGE=odoo:19
# POSTGRES_IMAGE=postgres:18

# Local bind defaults keep exposed services on localhost. Set these to 0.0.0.0
# only when you intentionally expose the services to your network.
# POSTGRES_HOST=127.0.0.1
# ODOO_HTTP_HOST=127.0.0.1
# ODOO_GEVENT_HOST=127.0.0.1
